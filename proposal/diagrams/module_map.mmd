    style EVAL  fill:#fff,stroke:#be0039,stroke-width:2px
    style AUTO  fill:#fff,stroke:#be0039,stroke-width:2px
    style QDATA fill:#fff,stroke:#be0039,stroke-width:2px
    style FLOW  fill:#fff,stroke:#be0039,stroke-width:2px
    style PROD  fill:#fff,stroke:#be0039,stroke-width:2px
    style DOC   fill:#fff,stroke:#be0039,stroke-width:2px
